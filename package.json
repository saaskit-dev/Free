{
  "name": "free",
  "version": "0.1.0",
  "private": true,
  "description": "Free remote relay, bridge, and host product built on acp-runtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "free": "dist/bin.js"
  },
  "files": [
    ".acp-runtime-ref",
    "dist",
    "relay/migrations",
    "relay/src",
    "relay/package.json",
    "relay/schema.sql",
    "relay/test-e2e.mjs",
    "relay/tsconfig.json",
    "relay/worker-configuration.d.ts",
    "relay/wrangler.jsonc",
    "Makefile",
    "scripts",
    "docs",
    "README.md"
  ],
  "bundledDependencies": [
    "@agentclientprotocol/sdk",
    "@opentelemetry/api",
    "@opentelemetry/api-logs",
    "@opentelemetry/sdk-logs",
    "@opentelemetry/sdk-trace-base",
    "tar",
    "unzipper",
    "ws",
    "zod",
    "@saaskit-dev/acp-runtime"
  ],
  "scripts": {
    "build": "make build",
    "build:self": "make build-self",
    "dev": "make dev",
    "lint": "make lint",
    "test": "make test",
    "relay:dev": "make relay-dev",
    "relay:deploy": "make relay-deploy",
    "remote:prod-smoke": "make remote-prod-smoke",
    "pack:local": "make pack-local",
    "postinstall": "node scripts/install-maintenance.cjs",
    "verify": "make verify"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.20.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "0.215.0",
    "@opentelemetry/sdk-logs": "0.215.0",
    "@opentelemetry/sdk-trace-base": "^1.9.1",
    "@saaskit-dev/acp-runtime": "file:../acp-runtime",
    "tar": "^7.5.13",
    "unzipper": "^0.12.3",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
