{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "acp-relay-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-27",
  "durable_objects": {
    "bindings": [
      {
        "class_name": "AcpRelayShard",
        "name": "ACP_RELAY_SHARDS"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["AcpRelayShard"],
      "tag": "v1"
    }
  ],
  "d1_databases": [
    {
      "binding": "ACP_RELAY_DB",
      "database_name": "acp-relay",
      "database_id": "2d8840b0-11b5-4f98-b006-a7c89636e489",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "ACP_RELAY_CLIENT_RECONNECT_GRACE_MS": "86400000",
    "ACP_RELAY_HOST_RECONNECT_GRACE_MS": "86400000",
    "ACP_RELAY_HEARTBEAT_INTERVAL_MS": "30000",
    "ACP_RELAY_HEARTBEAT_TIMEOUT_MS": "45000",
    "ACP_RELAY_MAX_BUFFERED_FRAMES_PER_CONNECTION": "64",
    "ACP_RELAY_MAX_CONNECTIONS_PER_ACCOUNT": "64"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "destinations": ["saaskit-otel-traces"],
      "head_sampling_rate": 1,
      "persist": false
    }
  }
}
