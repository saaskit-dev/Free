{
  "name": "@free/workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Free session workbench built with Expo, React Native, React Native Web, and Electron.",
  "main": "index.js",
  "scripts": {
    "dev": "expo start --web --port 8790",
    "web": "expo start --web --port 8790",
    "export:web": "expo export --platform web --output-dir dist --clear",
    "electron": "node ./scripts/electron-dev.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.3",
    "@hugeicons/react-native": "^1.0.13",
    "expo": "^54.0.0",
    "expo-font": "~14.0.8",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "electron": "^41.2.0",
    "typescript": "5.9.3"
  }
}
